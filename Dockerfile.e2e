FROM python:3.13-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

# Default: one peer (override in compose)
CMD ["python", "-m", "e2e.peer_worker", "--host", "0.0.0.0", "--port", "5201", "--control-port", "15201"]
